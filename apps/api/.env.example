# Postgres.app / local Postgres (no Docker):
DATABASE_URL=postgresql://kloqra:kloqra@localhost:5432/kloqra
REDIS_URL=redis://localhost:6379

# Or Docker: postgresql://kloqra:kloqra@localhost:5432/kloqra
# REDIS_USE_MEMORY=true
# Or Docker Redis: REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
FRONTEND_ORIGIN=http://localhost:3000,http://localhost:3002
PUBLIC_ADMIN_URL=http://localhost:3002
# Cross-site prod (Vercel + Railway): AUTH_COOKIE_SAME_SITE=none (auto-detected if omitted)
# AUTH_COOKIE_SAME_SITE=lax
# AUTH_COOKIE_SECURE=true
# REFRESH_ROTATION_GRACE_MS=10000
# COOKIE_DOMAIN=.kloqra.dev # Only for same-registrable-domain subdomains; omit for Vercel+Railway
PORT=3001

# Brevo SMTP (optional — emails no-op when BREVO_SMTP_KEY is unset)
# Free tier: 300 emails/day. Verify sender in Brevo dashboard.
# BREVO_SMTP_HOST=smtp-relay.brevo.com
# BREVO_SMTP_PORT=587
# BREVO_SMTP_USER=your-login@smtp-brevo.com
# BREVO_SMTP_KEY=your-brevo-smtp-key
# BREVO_SMTP_FROM=Kloqra <noreply@yourdomain.com>
