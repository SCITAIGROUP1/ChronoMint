# Production environment — copy values into Railway / Vercel dashboards.
# Use NEW secrets — never reuse staging JWT values.
# Generate secrets: bash scripts/deploy/generate-secrets.sh
# Full guide: docs/runbooks/railway.md

# --- Railway API service (kloqra-prod) ---
DATABASE_URL=${{Postgres.DATABASE_URL}}
REDIS_URL=<from Railway Redis plugin>
JWT_ACCESS_SECRET=<unique-32+-chars>
JWT_REFRESH_SECRET=<unique-32+-chars>
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
APP_URL=https://app.example.com
PUBLIC_PLATFORM_URL=https://platform.example.com
AUTH_COOKIE_SAME_SITE=none
AUTH_COOKIE_SECURE=true
REFRESH_ROTATION_GRACE_MS=10000
HARD_AUTO_STOP_HOURS=12
NODE_ENV=production
# Writable path for async export ZIP files (Railway containers cannot write to /app)
EXPORT_STORAGE_DIR=/tmp/export-jobs
# Product commercial features (rates/revenue/budgets/invoices). Default ON for production.
CLIENT_COMMERCIAL_FEATURES_ENABLED=true
# Do not set COOKIE_DOMAIN — cookies are stored on the API host only
# Do not set PORT — Railway injects it.

# SMTP (required for member invite / password emails)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=<your-smtp-login>
SMTP_PASS=<your-smtp-key>
SMTP_FROM=Kloqra <noreply@yourdomain.com>

# --- Vercel product app (kloqra-app, root apps/app) ---
NEXT_PUBLIC_API_BASE_URL=https://api.example.com
NEXT_PUBLIC_AUTH_SCOPE=app
NEXT_PUBLIC_HARD_AUTO_STOP_HOURS=12
NEXT_PUBLIC_CLIENT_COMMERCIAL_FEATURES=true

# --- Custom domains (Vercel Settings → Domains) ---
# App: app.example.com
# API: api.example.com (Railway → Settings → Networking → Custom Domain)
